# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Database
DATABASE_URL=postgresql://postgres:root@localhost:5432/devmind

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-this-to-a-long-random-secret-string
OTP_SECRET=another-long-random-secret-string

# Mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="DevMind <your-gmail@gmail.com>"
DASHBOARD_URL=https://your-dashboard-domain.com
BRAND_LOGO_URL=https://your-dashboard-domain.com/logo.png

# Payments
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
